# =============================================================
# Sports Application Web — 환경 변수 예시
# 실제 .env.local 파일을 생성해 값을 채운 뒤 사용합니다.
# .env.local은 .gitignore에 포함되어 있습니다. 절대 커밋하지 마세요.
# =============================================================

# ---- 서버 전용 (NEXT_PUBLIC_ 없음 = 클라이언트에 노출 안 됨) ----

# Spring Boot BE 서버 주소 (BFF Route Handler가 내부적으로 사용)
BACKEND_URL=http://localhost:8080

# ---- 클라이언트 공개 (NEXT_PUBLIC_ prefix = 브라우저에도 노출됨) ----

# 앱 표시 이름
NEXT_PUBLIC_APP_NAME=Sports Application
