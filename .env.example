# docker-compose.yml (base) 참조 키 예시.
# 실제 값은 .env(dev)/.env.dev/.env.prod에 두고 git에 커밋하지 않는다.

# 배포 이미지 태그 — local 개발: local(기본값), dev: latest, prod: 배포 커밋 SHA(rollback.sh가 치환)
DOCKER_TAG=local

# MySQL — base docker-compose.yml은 별도 app 계정을 생성하지 않으므로
# backend는 root 계정(DB_USERNAME=root)으로 mysql 서비스(내부 3306)에 접속한다.
# 따라서 DB_PASSWORD는 반드시 MYSQL_ROOT_PASSWORD와 같은 값이어야 한다 — 다르면 root 인증 실패로 backend가 기동하지 않는다.
DB_USERNAME=root
DB_PASSWORD=changeme-root-password

# MySQL root 계정 (컨테이너 초기화·헬스체크용) — 위 DB_PASSWORD와 반드시 동일한 값 유지
MYSQL_ROOT_PASSWORD=changeme-root-password

# docker-compose.observability.yml (opt-in) 참조 키 — observability 스택을 함께 띄울 때만 필요.
# backend(alerting.webhook-token)와 grafana-alerting-bootstrap이 동일 시크릿을 공유한다 — 값 불일치 시
# AlertWebhookApiController가 401로 드롭한다. observability 오버레이 없이 base만 기동할 때는 불필요.
ALERT_WEBHOOK_TOKEN=changeme-alert-webhook-token
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=changeme-grafana-admin-password
