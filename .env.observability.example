# .env.observability.example — 옵저버빌리티 스택 참조 변수 예시 (INFRA-05)
#
# 근거: TDD.md "Release Scenario"(OTLP 엔드포인트 no-op 플래그), ADR-005(env 태그 재사용),
#       FR-7 Operations. 관측 스택이 참조하는 변수의 "예시"이며 실제 값은 아래 규칙으로 관리한다.
#
# 로딩 규칙:
#   - 로컬(make observability-up): docker compose 가 루트 `.env` 를 자동 로드한다.
#     → 이 파일의 키를 `.env` 로 복사해 값을 채운다.
#   - dev/prod(make observability-dev|prod): `--env-file .env.dev|.env.prod` 를 명시 로드한다.
#     → 그 env 파일들은 배포 파이프라인(⑧)이 소유한다. 여기서는 참조만 한다.
#   - `.env*` 는 절대 git 커밋하지 않는다(.gitignore). 이 `.example` 만 커밋한다.
#
# 주의: backend 의 OTLP 엔드포인트는 docker-compose.observability.yml 이 이미 서비스명 기준
#       (http://otel-collector:4318...)으로 주입한다. 아래 값은 ① 비컨테이너 로컬 앱(gradlew bootRun)
#       ② web 서비스처럼 컨테이너 밖에서 발신하는 경우의 참조 예시다.

# ---- 환경 라벨 (ADR-005: 기존 env 태그 재사용, 신규 라벨 미도입) ----
# 앱은 management.metrics.tags.env 로 이 값을 메트릭 라벨에 부여한다.
# 로컬=local, dev=dev, prod=prod. dev/prod 값은 (8) env 파일이 소유.
APP_ENV=local

# ---- OTLP 발신 대상 (trace/log -> OTel Collector) ----
# Spring Boot 3.3.5 OTLP tracing 은 HTTP 전용 -> Collector HTTP 포트(4318) + /v1/traces 경로.
# (gRPC 포트 4317 로 보내면 export 가 끊겨 trace 연결율 99% 를 위협한다.)
MANAGEMENT_OTLP_TRACING_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL SDK 공통 base 엔드포인트(경로 없는 base — 로그 OTLP appender·SDK autoconfig 용).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# 비컨테이너 로컬 앱(호스트 실행)에서 컨테이너 Collector 로 보낼 때:
# MANAGEMENT_OTLP_TRACING_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---- service.name 규약 (Tempo·서비스맵에서 서비스를 구분하는 키) ----
# BE(Spring Boot) = sports-application / web(프론트) = sports-web.
# 서비스별로 각자 다른 값을 부여한다(한 값을 공유하면 trace 가 한 서비스로 뭉친다).
OTEL_SERVICE_NAME=sports-application
# web 서비스 예시:
# OTEL_SERVICE_NAME=sports-web

# ---- Grafana 관리자 계정 (docker-compose.observability.yml 참조) ----
# 미설정 시 기본값 admin/admin. 운영 노출 환경에서는 반드시 강한 값으로 치환한다.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
