# 외부 연동 mock↔실연동 전환 스위치 — 실제 값은 여기에 채우지 않는다.
#
# 전환 판정 기준: 무료 API 일일 요청 한도 ≥ 1,000건 (ADR-001, TDD "발급 주체 무료 API 전환 조사표").
# 판정 결과 — 카카오 지오코딩(100,000/day)·공공데이터포털 기상청 단기예보·공공체육시설
# (각 10,000/day, 동일 키 공유) 는 전환 대상, SOLAPI SMS 는 발신번호 사전등록 필요로 mock 유지.
#
# 전환 절차 (expand-contract, 무중단):
#   1) expand  — 아래 실 API key/base-url 을 배포 환경(.zshrc 또는 시크릿 매니저)에 주입한다.
#                이 파일(.env.sample)에는 절대 실제 값을 채우지 않는다 (평문 노출 0, PRD NFR).
#   2) switch  — 애플리케이션을 롤링 재기동한다. ConfigurationProperties 는 hot-reload 가
#                아니므로 재기동이 필요하다. 전환 조건 = `verifyExternalLive` gradle task 로
#                실 응답 무손실 역직렬화를 확인한 뒤 전환한다.
#   3) contract — 전환 확정 후에도 mock 서버(mock-servers/)는 제거하지 않는다.
#                 트래픽 시뮬레이터가 계속 mock 을 사용한다.
#   롤백 — 아래 env 를 배포 환경에서 제거하고 재기동하면 mock host(localhost:910x) 로 즉시
#          복귀한다. env 존재 여부가 피처 플래그와 동등하게 동작한다.
#
# 아래 값은 모두 placeholder 이며 값이 비어 있으면 애플리케이션은 자동으로 mock host 로 접속한다.

# 카카오 Local REST — 주소→좌표 지오코딩 (https://developers.kakao.com)
KAKAO_REST_API_KEY=

# 공공데이터포털 — 기상청 단기예보 + 공공체육시설 목록이 동일 키를 공유한다 (FR-3 동시 전환)
DATA_GO_KR_SERVICE_KEY=

# SOLAPI SMS — 발신번호 사전등록 필요, 현재 mock 유지 대상 (TDD "mock 영구 유지 분류")
SOLAPI_API_KEY=

# 실 API base-url — 값이 비어 있으면 docker-compose mock host(localhost:910x) 를 사용한다.
EXTERNAL_GEOCODING_BASE_URL=
EXTERNAL_PUBLIC_FACILITY_BASE_URL=
EXTERNAL_WEATHER_BASE_URL=
EXTERNAL_SMS_BASE_URL=
