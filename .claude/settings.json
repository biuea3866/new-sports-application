{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-local Claude Code settings. All hooks go through .claude/hooks/_run.sh which silently passes (exit 0) if the target script is missing — this prevents the deadlock where a moved/deleted hook script blocks every Write/Edit/Bash call. Hooks are scoped to THIS project only; no global hooks are registered.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/code-rules/harness-check.py file-guard"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/code-rules/harness-check.py code-pattern"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/feature-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/code-rules/harness-check.py git-guard"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/code-rules/harness-check.py bash-file-guard"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/feature-tdd-gate.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/push-test.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/pr-review-gate.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/qa-pr-defect-gate.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/qa-reverify-gate.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/qa-env-gate.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/worktree-isolation-guard.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/agent-merge-guard.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/wave-fanout-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/verify/subagent-verify.py"
          },
          {
            "type": "command",
            "command": "bash /Users/biuea/sports-application/.claude/hooks/_run.sh /Users/biuea/sports-application/.claude/hooks/workflow-gates/pr-review-tracker.sh"
          }
        ]
      }
    ]
  }
}