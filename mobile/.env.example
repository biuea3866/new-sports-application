# Backend API base URL (required)
# 클라이언트에 노출되는 공개 환경변수 — EXPO_PUBLIC_ 접두사 필수
EXPO_PUBLIC_API_URL=http://localhost:8080

# 앱 변형 (development / staging / production)
EXPO_PUBLIC_APP_VARIANT=development

# OpenTelemetry 트레이스 전송 대상 (OTel Collector OTLP HTTP — dev 한정)
# Android 에뮬레이터: http://10.0.2.2:4318 / 실기기: 호스트 LAN IP
# observability 스택 미기동 시 전송 실패는 무시되며 앱은 정상 동작
EXPO_PUBLIC_OTLP_ENDPOINT=http://localhost:4318
